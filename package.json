{
    "name": "trlc-vscode-extension",
    "version": "3.1.0",
    "publisher": "bmw-group",
    "author": {
        "name": "BMW Group"
    },
    "engines": {
        "vscode": "^1.116.0"
    },
    "icon": "assets/BMW_White-Colour_RGB.png",
    "license": "GPL-3.0-or-later",
    "displayName": "TRLC VSCode Extension",
    "description": "VSCode integration for the Python TRLC reference implementation",
    "homepage": "https://github.com/bmw-software-engineering/trlc-vscode-extension",
    "bugs": {
        "url": "https://github.com/bmw-software-engineering/trlc-vscode-extension/issues"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/bmw-software-engineering/trlc-vscode-extension.git"
    },
    "categories": [
        "Programming Languages",
        "Linters"
    ],
    "keywords": [
        "trlc",
        "requirements",
        "plain text",
        "bmw"
    ],
    "extensionDependencies": [
        "ms-python.python"
    ],
    "devDependencies": {
        "@types/node": "^22.19.17",
        "@types/vscode": "^1.116.0",
        "@typescript-eslint/eslint-plugin": "^8.58.2",
        "@typescript-eslint/parser": "^8.58.2",
        "@vscode/vsce": "^3.9.0",
        "esbuild": "^0.28.1",
        "eslint": "^9.39.4",
        "typescript": "^5.9.3"
    },
    "dependencies": {
        "vscode-languageclient": "^9.0.1"
    },
    "scripts": {
        "compile": "npm run check-types && node esbuild.js",
        "check-types": "tsc --noEmit",
        "watch": "npm-run-all -p watch:*",
        "watch:esbuild": "node esbuild.js --watch",
        "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
        "vscode:prepublish": "npm run package",
        "package": "npm run check-types && node esbuild.js --production"
    },
    "main": "client/out/extension",
    "activationEvents": [
        "onLanguage:TRLC"
    ],
    "contributes": {
        "languages": [
            {
                "id": "TRLC",
                "extensions": [
                    ".rsl",
                    ".trlc"
                ],
                "configuration": "./trlc-language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "TRLC",
                "scopeName": "source.trlc",
                "path": "./trlc-grammar.json"
            }
        ],
        "commands": [
            {
                "command": "extension.parseAll",
                "title": "TRLC: Parse All"
            },
            {
                "command": "extension.resetState",
                "title": "TRLC: Reset Setup"
            }
        ],
        "configuration": {
            "type": "object",
            "title": "trlc-vscode-extension server configuration",
            "properties": {
                "trlcServer.parsing": {
                    "scope": "window",
                    "type": "string",
                    "default": "partial",
                    "description": "Enable/Disable partial parsing. Set to full for complete parsing."
                },
                "trlcServer.verify": {
                    "scope": "window",
                    "type": "boolean",
                    "default": true,
                    "description": "Enable CVC5 formal verification of checks. Significantly increases parse time."
                },
                "trlcServer.excludePatterns": {
                    "scope": "window",
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [],
                    "description": "Regex patterns matched against directory names to exclude from TRLC include scanning. The pattern `^bazel-.*$` is always applied by default."
                }
            }
        }
    }
}
